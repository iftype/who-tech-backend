DATABASE_URL="file:./prisma/dev.db"

# GitHub Personal Access Token
# https://github.com/settings/tokens 에서 발급
# 필요 권한: public_repo (공개 레포 읽기)
GITHUB_TOKEN=

# 어드민 페이지 비밀키 (/admin/ui/admin.html)
ADMIN_SECRET=

# YouTube Data API v3 키 (테코톡 재생목록 수집용)
# https://console.cloud.google.com → YouTube Data API v3 사용 설정 후 발급
YOUTUBE_API_KEY=

# (선택) 테코톡 재생목록 ID 오버라이드. 미설정 시 우아한테크코스 기본 재생목록 사용
TECOTALK_PLAYLIST_ID=
