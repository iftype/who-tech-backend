{
  "name": "backend",
  "version": "1.0.1-beta",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/public dist/ && npm run build:admin",
    "build:admin": "cd src/public/admin-spa && npm run build",
    "dev:admin": "cd src/public/admin-spa && npm run dev",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest __tests__/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest __tests__/integration",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "seed": "tsx src/db/seed.ts",
    "seed:roles": "tsx src/scripts/seed-roles.ts",
    "bump:admin-version": "node -e \"const fs=require('fs'); const p='src/public/admin-spa/package.json'; const pkg=JSON.parse(fs.readFileSync(p,'utf-8')); const v=pkg.version.split('.'); v[2]=String(parseInt(v[2])+1); pkg.version=v.join('.'); fs.writeFileSync(p,JSON.stringify(pkg,null,2)+'\\n'); console.log('admin version bumped to', pkg.version);\""
  },
  "dependencies": {
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^6.19.2",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "p-queue": "^9.1.2",
    "prisma": "^6.19.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^15.4.2",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
